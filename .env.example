# =============================================================================
# YouEngage — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# DO NOT commit .env.local to version control.
# =============================================================================

# --- Database ---
# For Neon pooled connection (runtime):
DATABASE_URL="postgresql://user:pass@ep-xxx.region.neon.tech/youengage?sslmode=require"
# For Neon direct connection (migrations only):
DIRECT_URL="postgresql://user:pass@ep-xxx.region.neon.tech/youengage?sslmode=require"

# --- NextAuth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
# App URL (set to Vercel URL for production)
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# --- Microsoft Entra ID (Azure AD) SSO ---
# Create an App Registration in Azure Portal:
# 1. Go to Azure Portal → Microsoft Entra ID → App registrations → New registration
# 2. Name: YouEngage UAT
# 3. Redirect URI: https://your-app.vercel.app/api/auth/callback/microsoft-entra-id
# 4. Create a client secret under Certificates & secrets
# 5. Copy the values below
AUTH_MICROSOFT_ENTRA_ID_ID="your-azure-client-id"
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-azure-client-secret"
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="your-azure-tenant-id"

# --- Vercel Blob (File Storage) ---
# Auto-set by Vercel when Blob store is linked; set manually for local dev.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# --- File Upload ---
# Maximum file size in MB (default: 50)
MAX_FILE_SIZE_MB=50

# --- Dev Auth (local only, DO NOT set in production) ---
# DEV_AUTH=true
